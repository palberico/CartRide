rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Users — can read own doc; role is locked to rider/driver on create; cannot self-elevate
    match /users/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow create: if isAuth() && request.auth.uid == uid
        && request.resource.data.role in ['rider', 'driver'];
      allow update: if isAuth() && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    // Drivers — drivers read/write own doc; riders read all (to see map); admin reads/writes all
    match /drivers/{uid} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && (
        (request.auth.uid == uid
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['approved']))
        || role() == 'admin'
      );
    }

    // Common locations — anyone logged in can read; only admin can write
    match /commonLocations/{locId} {
      allow read: if isAuth();
      allow write: if isAuth() && role() == 'admin';
    }

    // Rides
    match /rides/{rideId} {
      // Only riders can create rides, and only for themselves
      allow create: if isAuth() && role() == 'rider'
        && request.resource.data.riderId == request.auth.uid;

      // Rider sees own rides; assigned driver sees their rides; all drivers see pending rides; admin sees all
      allow read: if isAuth() && (
        resource.data.riderId == request.auth.uid
        || resource.data.driverId == request.auth.uid
        || role() == 'driver'
        || role() == 'admin'
      );

      allow update: if isAuth() && (
        // Rider can cancel their own pending ride, or archive their completed ride
        (resource.data.riderId == request.auth.uid
          && (
            (resource.data.status == 'pending' && request.resource.data.status == 'cancelled')
            || (resource.data.status == 'completed' && request.resource.data.status == 'archived')
          )
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'updatedAt'])
        )
        ||
        // Any approved driver can accept an unassigned pending ride
        (role() == 'driver'
          && resource.data.status == 'pending'
          && resource.data.driverId == null
          && request.resource.data.status == 'accepted'
        )
        ||
        // The assigned driver can advance the ride through valid statuses
        (resource.data.driverId == request.auth.uid
          && request.resource.data.status in ['active', 'ending', 'completed']
        )
        ||
        role() == 'admin'
      );
    }
  }
}
